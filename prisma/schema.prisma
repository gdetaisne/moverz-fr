generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["seo"]
}

// ─── GSC ─────────────────────────────────────────────────────────────────────

// Une ligne par exécution du script gsc-monitor.mjs
model GscSnapshot {
  id          String   @id @default(cuid())
  fetchedAt   DateTime @default(now())
  days        Int
  periodStart DateTime
  periodEnd   DateTime
  prevStart   DateTime
  prevEnd     DateTime

  totals     GscTotals?
  pageMetrics GscPageMetric[]
  queryMetrics GscQueryMetric[]
  pageQueryMetrics GscPageQueryMetric[]
  alerts     GscAlert[]

  @@unique([periodStart, periodEnd])
  @@index([fetchedAt])
  @@schema("seo")
}

// Agrégats globaux du snapshot (current + previous)
model GscTotals {
  id             String      @id @default(cuid())
  snapshot       GscSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  snapshotId     String      @unique

  // Période courante
  clicks         Int
  impressions    Int
  ctr            Float
  // Période précédente
  clicksPrev     Int
  impressionsPrev Int
  ctrPrev        Float
  // Deltas
  clicksDelta    Int
  clicksPct      Float?
  impressionsDelta Int
  impressionsPct   Float?
  @@schema("seo")
}

// Performance par page × jour (granularité : 1 ligne = 1 page × 1 jour)
model GscPageMetric {
  id          String      @id @default(cuid())
  snapshot    GscSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  snapshotId  String
  date        DateTime    @db.Date
  url         String
  cluster     String      // Blog | Villes (core) | Corridors | Guides villes | etc.
  clicks      Int
  impressions Int
  ctr         Float
  position    Float

  @@index([url, date])
  @@index([cluster, date])
  @@index([snapshotId])
  @@schema("seo")
}

// Performance par requête × jour
model GscQueryMetric {
  id          String      @id @default(cuid())
  snapshot    GscSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  snapshotId  String
  date        DateTime    @db.Date
  query       String
  clicks      Int
  impressions Int
  ctr         Float
  position    Float

  @@index([query, date])
  @@index([snapshotId])
  @@schema("seo")
}

// Granularité maximale : page × requête × jour
model GscPageQueryMetric {
  id          String      @id @default(cuid())
  snapshot    GscSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  snapshotId  String
  date        DateTime    @db.Date
  url         String
  query       String
  clicks      Int
  impressions Int
  ctr         Float
  position    Float

  @@index([url, query])
  @@index([url, date])
  @@index([date])
  @@index([snapshotId])
  @@schema("seo")
}

// Alertes déclenchées lors d'un snapshot
model GscAlert {
  id         String      @id @default(cuid())
  snapshot   GscSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  snapshotId String
  level      String      // INFO | WARNING | CRITICAL
  cluster    String?
  message    String

  @@index([snapshotId])
  @@index([level])
  @@schema("seo")
}
