{
  "name": "moverz-hub",
  "version": "1.0.0",
  "private": true,
  "description": "Moverz - Comparateur de devis de déménageurs (Hub National)",
  "scripts": {
    "prebuild": "tsx --tsconfig tsconfig.json scripts/generate-premium-city-guides.ts",
    "dev": "NODE_ENV=development next dev -p 3040",
    "build": "next build",
    "start": "next start -p 3040",
    "lint": "next lint",
    "prewarm": "node scripts/prewarm-cache.mjs",
    "prewarm:purge": "node scripts/prewarm-cache.mjs --purge",
    "deploy": "git push && echo 'Build CapRover en cours (4 min)...' && sleep 240 && node scripts/prewarm-cache.mjs",
    "test": "vitest run",
    "blog:pro:gen": "tsx scripts/generate-blog-pro.ts",
    "scrape:competitors": "tsx scripts/scrape-competitors.ts",
    "analyze:gaps": "tsx scripts/analyze-gaps.ts",
    "seo:inventory": "tsx scripts/seo-inventory.ts > seo-inventory.csv",
    "seo:healthcheck": "tsx scripts/seo-healthcheck.ts",
    "seo:city-guides-wordcount": "tsx scripts/seo-city-guides-wordcount.ts > seo-city-guides-wordcount.csv",
    "seo:audit-blog": "tsx scripts/audit-blog-content.ts",
    "seo:monitor": "node scripts/gsc-monitor.mjs",
    "seo:monitor:weekly": "node scripts/gsc-monitor.mjs --days 7",
    "seo:monitor:monthly": "node scripts/gsc-monitor.mjs --days 28"
  },
  "dependencies": {
    "@googlemaps/markerclusterer": "^2.6.2",
    "@marsidev/react-turnstile": "^1.4.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/qrcode": "^1.5.6",
    "@vis.gl/react-google-maps": "^1.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.25",
    "googleapis": "^171.4.0",
    "jose": "^6.2.1",
    "lucide-react": "^0.453.0",
    "next": "^14.2.15",
    "next-sitemap": "^4.2.3",
    "nodemailer": "^7.0.12",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/cheerio": "^0.22.35",
    "@types/node": "20.19.18",
    "@types/react": "19.1.13",
    "autoprefixer": "^10.4.20",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "postcss": "^8.4.47",
    "prisma": "^7.5.0",
    "tailwindcss": "^3.4.10",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "5.9.2",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  }
}
